  document.getElementById('image-input').addEventListener('change', e => handleFileInput(e, 'image'));
  document.getElementById('camera-input').addEventListener('change', e => handleFileInput(e, 'image'));
  document.getElementById('file-input').addEventListener('change', e => handleFileInput(e, 'file'));

  // Suggestion pills
  bindPills();
}

function setNav(id) {
  document.querySelectorAll('.sidebar-item').forEach(i=>i.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-overlay').classList.add('hidden');
  document.getElementById('chat-title') && (document.getElementById('chat-title').textContent='');
}

function bindPills() {
  document.querySelectorAll('.pill').forEach(p => {
    p.addEventListener('click', () => sendMessage(p.dataset.q));
  });
}

function doSend() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text && !state.attachments.length) return;
  input.value = '';
  input.style.height = 'auto';
  sendMessage(text);
}

function handleFileInput(e, type) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  if (type === 'image') {
    reader.onload = ev => addAttachment('image', ev.target.result, file.name);
    reader.readAsDataURL(file);
  } else {
    reader.onload = ev => addAttachment('file', ev.target.result, file.name);
    reader.readAsDataURL(file);
  }
  e.target.value = '';
}

function launchApp() {
  updateAiStatus(true);
  document.getElementById('model-badge').textContent = state.model;
  showScreen('app-screen');
  bindPills();
  // Greet with context if first time
  if (state.chatHistory.length === 0 && state.facialReport) {
    setTimeout(() => {
      const report = state.facialReport;
      const positiveNames = report.positives.map(([k])=>k).join(', ');
      const improvNames = report.improvements.map(([k])=>k).join(', ');
      const greeting = `Welcome! I've reviewed your facial analysis report. Your scan highlights some excellent attributes including ${positiveNames}. The key growth opportunities identified are ${improvNames}.\n\nBased on your age of ${report.age || 'your age'}, I can provide tailored guidance to optimise your results. How would you like to begin — shall I start with the foundational mewing technique, or would you prefer a personalised plan?`;
      addMessage('assistant', greeting);
      state.chatHistory.push({ role:'assistant', content: greeting });
      localStorage.setItem('siq_history', JSON.stringify(state.chatHistory));
    }, 600);
  }
}
</script>
