<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StructureIQ — AI Facial Analysis</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
<style>
  :root {
    --bg: #0a0a0b;
    --bg2: #111115;
    --bg3: #18181e;
    --surface: #1e1e26;
    --surface2: #25252f;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #f0ede8;
    --text2: #9997a0;
    --text3: #5a5865;
    --gold: #c9a96e;
    --gold2: #e8c98a;
    --gold-dim: rgba(201,169,110,0.15);
    --gold-glow: rgba(201,169,110,0.25);
    --accent: #c9a96e;
    --user-bubble: #1e1e26;
    --ai-bubble: #141418;
    --radius: 16px;
    --radius-sm: 10px;
    --shadow: 0 8px 40px rgba(0,0,0,0.5);
    --shadow-sm: 0 2px 12px rgba(0,0,0,0.3);
  }
  [data-theme="light"] {
    --bg: #f5f3ef;
    --bg2: #ede9e2;
    --bg3: #e6e1d8;
    --surface: #ffffff;
    --surface2: #f9f7f4;
    --border: rgba(0,0,0,0.08);
    --border2: rgba(0,0,0,0.14);
    --text: #1a1814;
    --text2: #6b6760;
    --text3: #a8a49e;
    --gold: #a07840;
    --gold2: #8a6030;
    --gold-dim: rgba(160,120,64,0.1);
    --gold-glow: rgba(160,120,64,0.2);
    --user-bubble: #f0ece5;
    --ai-bubble: #ffffff;
    --shadow: 0 8px 40px rgba(0,0,0,0.12);
    --shadow-sm: 0 2px 12px rgba(0,0,0,0.08);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow: hidden;
    transition: background 0.3s, color 0.3s;
  }
  /* ===== NOISE TEXTURE OVERLAY ===== */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* ===== SCREENS ===== */
  .screen { position:fixed; inset:0; display:flex; align-items:center; justify-content:center; z-index:100; transition: opacity 0.5s, transform 0.5s; }
  .screen.hidden { opacity:0; pointer-events:none; transform: scale(0.97); }

  /* ===== GRADIENT BACKGROUNDS ===== */
  .radial-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 20%, var(--gold-dim), transparent 60%);
    pointer-events: none;
  }

  /* ===== LOGO ===== */
  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: 0.18em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .logo span { color: var(--text2); font-weight: 300; }

  /* ===== CARDS ===== */
  .card {
    background: var(--surface);
    border: 1px solid var(--border2);
    border-radius: 24px;
    padding: 48px;
    max-width: 480px;
    width: 90%;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0.5;
  }

  /* ===== TYPOGRAPHY ===== */
  h1 { font-family:'Cormorant Garamond',serif; font-size:2.4rem; font-weight:300; line-height:1.2; margin-bottom:0.5rem; }
  h2 { font-family:'Cormorant Garamond',serif; font-size:1.8rem; font-weight:300; line-height:1.3; }
  .subtitle { color:var(--text2); font-size:0.9rem; line-height:1.6; margin-top:0.5rem; }
  .step-badge {
    display:inline-block;
    background: var(--gold-dim);
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 1.2rem;
  }

  /* ===== INPUTS ===== */
  .input-group { margin-top: 1.8rem; }
  .input-label { font-size:0.78rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--text2); margin-bottom:8px; display:block; }
  .input-field {
    width: 100%;
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .input-field:focus { border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-dim); }
  .input-field::placeholder { color: var(--text3); }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex; align-items:center; gap:8px;
    padding: 14px 28px;
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
    letter-spacing: 0.03em;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--gold), var(--gold2));
    color: #0a0805;
    box-shadow: 0 4px 20px var(--gold-glow);
  }
  .btn-primary:hover { transform:translateY(-1px); box-shadow: 0 6px 28px var(--gold-glow); }
  .btn-ghost {
    background: transparent;
    color: var(--text2);
    border: 1px solid var(--border2);
  }
  .btn-ghost:hover { background: var(--surface2); color: var(--text); }
  .btn-full { width:100%; justify-content:center; margin-top:1.5rem; }

  /* ===== DIVIDER ===== */
  .divider { height:1px; background:var(--border); margin: 1.5rem 0; }

  /* ===== CAMERA PREVIEW ===== */
  #camera-preview {
    width:100%; aspect-ratio:4/3;
    border-radius:var(--radius);
    background:var(--bg2);
    border: 1px solid var(--border2);
    overflow:hidden;
    position:relative;
    margin-bottom:1.2rem;
  }
  #camera-preview video, #camera-preview canvas {
    width:100%; height:100%; object-fit:cover; display:block;
  }
  .camera-overlay {
    position:absolute;inset:0;pointer-events:none;
    background: radial-gradient(ellipse 60% 80% at 50% 40%, transparent 45%, rgba(0,0,0,0.5) 100%);
  }
  .face-guide {
    position:absolute; top:50%; left:50%; transform:translate(-50%,-55%);
    width:55%; aspect-ratio:3/4;
    border:2px solid var(--gold);
    border-radius:50% 50% 45% 45%;
    opacity:0.6;
    box-shadow: 0 0 0 1px rgba(201,169,110,0.2), inset 0 0 0 1px rgba(201,169,110,0.2);
  }
  .cam-status {
    position:absolute;bottom:10px;left:50%;transform:translateX(-50%);
    background:rgba(0,0,0,0.6);color:var(--gold);
    padding:4px 12px;border-radius:100px;font-size:0.75rem;
    backdrop-filter:blur(8px);
  }

  /* ===== ANALYSIS REPORT ===== */
  .report-section { margin-top:1.2rem; }
  .report-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:0.8rem; }
  .report-chip {
    padding:10px 14px; border-radius:10px; font-size:0.82rem; line-height:1.4;
  }
  .chip-pos { background:rgba(100,200,100,0.08); border:1px solid rgba(100,200,100,0.2); color:#7dd47d; }
  .chip-imp { background:rgba(201,169,110,0.08); border:1px solid rgba(201,169,110,0.2); color:var(--gold); }
  .score-bar { margin-top:1.5rem; }
  .score-label { display:flex;justify-content:space-between; font-size:0.8rem; color:var(--text2); margin-bottom:6px; }
  .bar-track { height:6px; background:var(--bg2); border-radius:100px; overflow:hidden; }
  .bar-fill { height:100%; border-radius:100px; background:linear-gradient(90deg,var(--gold),var(--gold2)); transition:width 1s ease; }

  /* ===== MAIN APP LAYOUT ===== */
  #app-screen {
    flex-direction:column;
    align-items:stretch;
    background: var(--bg);
  }
  .app-layout { display:flex; height:100vh; width:100%; }

  /* ===== SIDEBAR ===== */
  .sidebar {
    width:260px; flex-shrink:0;
    background:var(--bg2);
    border-right:1px solid var(--border);
    display:flex; flex-direction:column;
    padding:20px 0;
    transition: transform 0.3s, width 0.3s;
  }
  .sidebar-logo { padding:0 20px 20px; border-bottom:1px solid var(--border); margin-bottom:16px; }
  .sidebar-logo .logo { font-size:1.4rem; }
  .sidebar-section-label {
    font-size:0.68rem; letter-spacing:0.12em; text-transform:uppercase;
    color:var(--text3); padding:0 20px 8px; margin-top:8px;
  }
  .sidebar-item {
    display:flex; align-items:center; gap:10px;
    padding:10px 20px; cursor:pointer; border-radius:0;
    color:var(--text2); font-size:0.88rem;
    transition:all 0.15s; position:relative;
  }
  .sidebar-item:hover { background:var(--surface); color:var(--text); }
  .sidebar-item.active { background:var(--gold-dim); color:var(--gold); }
  .sidebar-item.active::before {
    content:''; position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--gold);
  }
  .sidebar-icon { font-size:1rem; width:20px; text-align:center; flex-shrink:0; }
  .sidebar-bottom { margin-top:auto; padding:16px 20px; border-top:1px solid var(--border); }

  /* ===== MAIN CHAT AREA ===== */
  .main-area { flex:1; display:flex; flex-direction:column; overflow:hidden; }
  .chat-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 24px; border-bottom:1px solid var(--border);
    background:var(--bg);
  }
  .chat-title { font-family:'Cormorant Garamond',serif; font-size:1.3rem; font-weight:300; }
  .header-actions { display:flex; gap:8px; }
  .icon-btn {
    width:36px; height:36px; border-radius:8px;
    background:transparent; border:1px solid var(--border2);
    color:var(--text2); cursor:pointer; display:flex; align-items:center; justify-content:center;
    font-size:1rem; transition:all 0.15s;
  }
  .icon-btn:hover { background:var(--surface2); color:var(--text); }

  /* ===== MESSAGES ===== */
  .messages {
    flex:1; overflow-y:auto; padding:24px;
    scroll-behavior:smooth;
  }
  .messages::-webkit-scrollbar { width:6px; }
  .messages::-webkit-scrollbar-track { background:transparent; }
  .messages::-webkit-scrollbar-thumb { background:var(--surface2); border-radius:100px; }
  .message { display:flex; gap:12px; margin-bottom:20px; animation: msgIn 0.3s ease; }
  @keyframes msgIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }
  .message.user { flex-direction:row-reverse; }
  .avatar {
    width:34px; height:34px; border-radius:50%; flex-shrink:0;
    display:flex; align-items:center; justify-content:center; font-size:0.85rem;
  }
  .avatar-ai { background:var(--gold-dim); border:1px solid rgba(201,169,110,0.3); color:var(--gold); }
  .avatar-user { background:var(--surface2); border:1px solid var(--border2); color:var(--text2); font-size:0.8rem; }
  .bubble {
    max-width:72%; padding:14px 18px; border-radius:var(--radius);
    font-size:0.9rem; line-height:1.65;
  }
  .bubble-ai { background:var(--ai-bubble); border:1px solid var(--border); border-top-left-radius:4px; }
  .bubble-user { background:var(--user-bubble); border:1px solid var(--border2); border-top-right-radius:4px; color:var(--text); }
  .bubble img { max-width:100%; border-radius:10px; margin-top:8px; display:block; }
  .bubble p { margin-bottom:0.5rem; }
  .bubble p:last-child { margin-bottom:0; }
  .bubble code { background:var(--surface2); padding:2px 6px; border-radius:4px; font-size:0.85em; }
  .bubble pre { background:var(--bg2); border:1px solid var(--border); border-radius:10px; padding:12px; overflow-x:auto; margin:8px 0; }
  .bubble pre code { background:none; padding:0; }
  .bubble ul, .bubble ol { padding-left:1.4rem; margin:0.4rem 0; }
  .bubble strong { color:var(--gold); font-weight:500; }
  .bubble h1,.bubble h2,.bubble h3 { font-family:'Cormorant Garamond',serif; margin:0.6rem 0 0.3rem; }
  .typing { display:flex; gap:4px; align-items:center; padding:16px 18px; }
  .typing span { width:6px; height:6px; background:var(--text3); border-radius:50%; animation:dot 1.2s infinite; }
  .typing span:nth-child(2) { animation-delay:0.2s; }
  .typing span:nth-child(3) { animation-delay:0.4s; }
  @keyframes dot { 0%,60%,100%{transform:none;opacity:0.4}30%{transform:translateY(-5px);opacity:1} }

  /* ===== INPUT BAR ===== */
  .input-bar {
    border-top:1px solid var(--border);
    padding:16px 24px;
    background:var(--bg);
  }
  .input-attachments { display:flex; gap:8px; margin-bottom:10px; flex-wrap:wrap; }
  .attachment-preview {
    position:relative; width:64px; height:64px; border-radius:10px; overflow:hidden;
    border:1px solid var(--border2); flex-shrink:0;
  }
  .attachment-preview img { width:100%;height:100%;object-fit:cover; }
  .attachment-preview .remove-att {
    position:absolute;top:2px;right:2px;width:18px;height:18px;
    background:rgba(0,0,0,0.7);border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-size:0.6rem;color:#fff;cursor:pointer;
  }
  .attachment-file {
    display:flex;align-items:center;gap:6px;padding:6px 10px;
    background:var(--surface);border:1px solid var(--border2);border-radius:8px;
    font-size:0.78rem;color:var(--text2);max-width:160px;
  }
  .attachment-file .remove-att { position:static;width:16px;height:16px;background:var(--surface2);margin-left:auto; }
  .input-row { display:flex; gap:10px; align-items:flex-end; }
  .input-tools { display:flex; gap:6px; }
  .tool-btn {
    width:36px;height:36px;border-radius:8px;border:1px solid var(--border2);
    background:transparent;color:var(--text2);cursor:pointer;
    display:flex;align-items:center;justify-content:center;font-size:1rem;
    transition:all 0.15s;flex-shrink:0;
  }
  .tool-btn:hover { background:var(--surface2);color:var(--text); }
  .chat-input {
    flex:1;resize:none;min-height:44px;max-height:140px;
    background:var(--surface);border:1px solid var(--border2);
    border-radius:var(--radius-sm);padding:12px 16px;
    color:var(--text);font-family:'DM Sans',sans-serif;font-size:0.92rem;
    outline:none;transition:border-color 0.2s;line-height:1.5;
  }
  .chat-input:focus { border-color:var(--gold); }
  .chat-input::placeholder { color:var(--text3); }
  .send-btn {
    width:44px;height:44px;border-radius:10px;border:none;flex-shrink:0;
    background:linear-gradient(135deg,var(--gold),var(--gold2));
    color:#0a0805;cursor:pointer;display:flex;align-items:center;justify-content:center;
    font-size:1.1rem;transition:all 0.2s;box-shadow:0 4px 14px var(--gold-glow);
  }
  .send-btn:hover { transform:translateY(-1px); }
  .send-btn:disabled { opacity:0.5;cursor:not-allowed;transform:none; }

  /* ===== SIDEBAR OVERLAY (MOBILE) ===== */
  .sidebar-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200; }
  .sidebar-overlay.hidden { display:none !important; }

  /* ===== SETTINGS PANEL ===== */
  .panel-overlay {
    position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:500;
    display:flex;align-items:center;justify-content:center;
    opacity:0;pointer-events:none;transition:opacity 0.3s;
    backdrop-filter:blur(4px);
  }
  .panel-overlay.open { opacity:1;pointer-events:all; }
  .settings-panel {
    background:var(--surface);border:1px solid var(--border2);border-radius:24px;
    padding:36px;max-width:440px;width:90%;max-height:90vh;overflow-y:auto;
    box-shadow:var(--shadow);
    transform:scale(0.95);transition:transform 0.3s;
  }
  .panel-overlay.open .settings-panel { transform:scale(1); }
  .panel-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:28px; }
  .close-btn {
    width:32px;height:32px;border-radius:8px;border:1px solid var(--border2);
    background:transparent;color:var(--text2);cursor:pointer;font-size:1rem;
    display:flex;align-items:center;justify-content:center;transition:all 0.15s;
  }
  .close-btn:hover { background:var(--surface2);color:var(--text); }
  .settings-section { margin-bottom:24px; }
  .settings-section h3 { font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:400;margin-bottom:14px;color:var(--text2); }
  .theme-grid { display:grid;grid-template-columns:1fr 1fr;gap:8px; }
  .theme-btn {
    padding:12px;border-radius:10px;border:1px solid var(--border2);
    background:transparent;color:var(--text2);cursor:pointer;
    font-family:'DM Sans',sans-serif;font-size:0.85rem;
    transition:all 0.15s;text-align:center;
  }
  .theme-btn:hover { background:var(--surface2);color:var(--text); }
  .theme-btn.active { border-color:var(--gold);background:var(--gold-dim);color:var(--gold); }
  .accent-row { display:flex;gap:8px;margin-top:10px;flex-wrap:wrap; }
  .accent-dot {
    width:28px;height:28px;border-radius:50%;cursor:pointer;
    border:2px solid transparent;transition:all 0.15s;
  }
  .accent-dot:hover,.accent-dot.active { border-color:var(--text);transform:scale(1.1); }
  .status-indicator {
    display:inline-flex;align-items:center;gap:6px;
    padding:4px 10px;border-radius:100px;font-size:0.78rem;
    background:rgba(100,200,100,0.1);border:1px solid rgba(100,200,100,0.2);
    color:#7dd47d;
  }
  .status-dot { width:6px;height:6px;border-radius:50%;background:#7dd47d;animation:pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.4} }
  .status-indicator.offline { background:rgba(255,100,100,0.1);border-color:rgba(255,100,100,0.2);color:#f07070; }
  .status-indicator.offline .status-dot { background:#f07070;animation:none; }

  /* ===== WELCOME EMPTY STATE ===== */
  .welcome-state {
    flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
    padding:40px 24px;text-align:center;
  }
  .welcome-icon { font-size:3rem;margin-bottom:16px;opacity:0.6; }
  .welcome-state h2 { font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;margin-bottom:8px; }
  .welcome-state p { color:var(--text2);font-size:0.9rem;max-width:360px;line-height:1.6; }
  .suggestion-pills { display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:20px;max-width:500px; }
  .pill {
    padding:8px 16px;border-radius:100px;border:1px solid var(--border2);
    background:var(--surface);color:var(--text2);font-size:0.82rem;cursor:pointer;
    transition:all 0.15s;
  }
  .pill:hover { border-color:var(--gold);color:var(--gold);background:var(--gold-dim); }

  /* ===== SCAN MODE BUTTONS ===== */
  .scan-mode-btn {
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 12px;
    padding: 14px 8px;
    color: var(--text2);
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    text-align: center;
    transition: all 0.18s;
    line-height: 1.3;
  }
  .scan-mode-btn:hover { background: var(--bg3); color: var(--text); }
  .scan-mode-btn.active {
    background: var(--gold-dim);
    border-color: var(--gold);
    color: var(--gold);
  }

  /* ===== UPLOAD DROP ZONE ===== */
  #upload-drop-zone {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: var(--radius);
    background: var(--bg2);
    border: 2px dashed var(--border2);
    overflow: hidden;
    position: relative;
    margin-bottom: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s;
  }
  #upload-drop-zone:hover { border-color: var(--gold); }
  #upload-drop-zone.has-image { border-style: solid; border-color: var(--gold); }
  #upload-placeholder { text-align: center; pointer-events: none; }
  #upload-preview-wrap { position: absolute; inset: 0; }

  /* ===== PROGRESS / LOADING ===== */
  .analyzing-overlay {
    position:absolute;inset:0;background:rgba(10,10,11,0.85);
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    border-radius:var(--radius);gap:12px;backdrop-filter:blur(4px);
  }
  .spinner {
    width:48px;height:48px;border-radius:50%;
