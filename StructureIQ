function addMessage(role, content, html=false) {
  const container = document.getElementById('messages-container');
  const welcome = document.getElementById('welcome-state');
  if (welcome) welcome.remove();

  const div = document.createElement('div');
  div.className = `message ${role}`;
  const avatarClass = role === 'user' ? 'avatar-user' : 'avatar-ai';
  const avatarContent = role === 'user' ? '👤' : '◈';
  let bubbleContent = '';
  if (html) {
    bubbleContent = content;
  } else {
    bubbleContent = role === 'assistant' ? marked.parse(content) : `<p>${escapeHtml(content)}</p>`;
  }
  div.innerHTML = `
    <div class="avatar ${avatarClass}">${avatarContent}</div>
    <div class="bubble bubble-${role==='user'?'user':'ai'}">${bubbleContent}</div>
  `;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
  return div;
}
function escapeHtml(t) { return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function showTyping() {
  const container = document.getElementById('messages-container');
  const welcome = document.getElementById('welcome-state');
  if (welcome) welcome.remove();
  const div = document.createElement('div');
  div.className = 'message assistant';
