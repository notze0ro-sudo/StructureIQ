<script>
// ============================================================
//  STATE
// ============================================================
const state = {
  age: null,
  apiKey: localStorage.getItem('siq_api_key') || '',
  model: localStorage.getItem('siq_model') || '',
  theme: localStorage.getItem('siq_theme') || 'dark',
  accent: localStorage.getItem('siq_accent') || 'gold',
  chatHistory: JSON.parse(localStorage.getItem('siq_history') || '[]'),
  memory: JSON.parse(localStorage.getItem('siq_memory') || '[]'),
  facialReport: JSON.parse(localStorage.getItem('siq_report') || 'null'),
  attachments: [],
  stream: null,
  isTyping: false
};

const SYSTEM_PROMPT = `You are StructureIQ, a highly professional AI specialist in craniofacial development, mewing technique, orthotropics, and facial structure optimization. You provide evidence-informed guidance on:

- Correct mewing tongue posture and technique  
- Hard mewing vs soft mewing
- Facial bone structure and how it can be influenced
- Jaw, palate, and nasal development
- Breathing optimization (nasal vs mouth breathing)
- Posture and its effect on facial development
- Personalised exercise and mewing plans

Your communication style is professional, warm, and precise. You use structured responses with headers and bullet points when appropriate. You always remind users that significant structural changes take months to years and that you are an AI, not a medical professional — recommend consulting orthodontists or maxillofacial specialists for clinical advice.

You REMEMBER previous conversations — reference past discussions naturally when relevant.

When users ask for image generation, describe in detail what the image would show (since you cannot generate actual images in this interface).`;

// ============================================================
//  INIT
// ============================================================
window.addEventListener('DOMContentLoaded', () => {
  applyTheme(state.theme);
  applyAccent(state.accent);
  populateSettings();
  if (state.apiKey && state.model) updateAiStatus(true);

  document.getElementById('model-badge').textContent = state.model || '';

  // Show age screen
  showScreen('age-screen');
  bindEvents();
  renderHistory();
});

// ============================================================
//  SCREEN MANAGEMENT
// ============================================================
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.add('hidden'));
  document.getElementById(id).classList.remove('hidden');
}

// ============================================================
//  THEME & ACCENT
// ============================================================
const accentPalettes = {
  gold:     { main:'#c9a96e', light:'#e8c98a', dim:'rgba(201,169,110,0.15)', glow:'rgba(201,169,110,0.25)' },
  rose:     { main:'#c96e8a', light:'#e89ab0', dim:'rgba(201,110,138,0.15)', glow:'rgba(201,110,138,0.25)' },
  sage:     { main:'#6e9c7a', light:'#9ac2a4', dim:'rgba(110,156,122,0.15)', glow:'rgba(110,156,122,0.25)' },
  slate:    { main:'#6e8aa0', light:'#9ab8cc', dim:'rgba(110,138,160,0.15)', glow:'rgba(110,138,160,0.25)' },
  lavender: { main:'#8a7ac9', light:'#b0a0e8', dim:'rgba(138,122,201,0.15)', glow:'rgba(138,122,201,0.25)' },
};
function applyTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  document.querySelectorAll('.theme-btn').forEach(b => b.classList.toggle('active', b.dataset.theme === t));
  state.theme = t;
  localStorage.setItem('siq_theme', t);
}
function applyAccent(a) {
  const p = accentPalettes[a] || accentPalettes.gold;
  const root = document.documentElement.style;
  root.setProperty('--gold', p.main);
  root.setProperty('--gold2', p.light);
  root.setProperty('--gold-dim', p.dim);
  root.setProperty('--gold-glow', p.glow);
  root.setProperty('--accent', p.main);
  document.querySelectorAll('.accent-dot').forEach(d => d.classList.toggle('active', d.dataset.accent === a));
  state.accent = a;
  localStorage.setItem('siq_accent', a);
}

// ============================================================
//  SCAN MODE MANAGEMENT
// ============================================================
let currentScanMode = 'live';
let mediaStream = null;

function setScanMode(mode) {
  currentScanMode = mode;
  // Update button states
  ['live','upload','skip'].forEach(m => {
    document.getElementById('mode-'+m).classList.toggle('active', m === mode);
  });
  // Show/hide panels
  document.getElementById('panel-live').style.display   = mode==='live'   ? 'block' : 'none';
  document.getElementById('panel-upload').style.display = mode==='upload' ? 'block' : 'none';
  document.getElementById('panel-skip').style.display   = mode==='skip'   ? 'block' : 'none';

  if (mode === 'live') { setupCamera(); }
  else { stopCamera(); }
}

async function setupCamera() {
  const video = document.getElementById('cam-video');
  const status = document.getElementById('cam-status');
  const captureBtn = document.getElementById('capture-btn');
  const errBox = document.getElementById('cam-error-box');
  errBox.style.display = 'none';
  captureBtn.disabled = true;
  status.textContent = 'Requesting camera access…';

  // Check API availability
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    showCamError(
      captureBtn, errBox, status,
      '⚠️ Camera API unavailable in this context. This usually happens when the file is opened directly from your file system (<code>file://</code>).<br><br>' +
      '<strong>Solutions:</strong><br>'+
      '• Switch to the <strong>Upload Photo</strong> tab above<br>'+
      '• Or use <strong>Skip & Analyse</strong> to get a general report<br>'+
      '• To use live camera, host this file on a local server or open via <code>localhost</code>'
    );
    return;
  }

  // Try to get camera
  const constraints = [
    { video: { facingMode: 'user', width: { ideal:640 }, height: { ideal:480 } }, audio: false },
    { video: { facingMode: 'user' }, audio: false },
    { video: true, audio: false },
  ];

  let lastError = null;
  for (const c of constraints) {
    try {
      mediaStream = await navigator.mediaDevices.getUserMedia(c);
      break;
    } catch(e) {
      lastError = e;
      mediaStream = null;
    }
  }

  if (!mediaStream) {
    let reason = '';
    if (lastError) {
      if (lastError.name === 'NotAllowedError' || lastError.name === 'PermissionDeniedError') {
        reason = '🔒 <strong>Camera permission was denied.</strong><br>Please allow camera access in your browser settings, then click Retry.';
      } else if (lastError.name === 'NotFoundError' || lastError.name === 'DevicesNotFoundError') {
        reason = '🔍 <strong>No camera device found.</strong><br>Your device may not have a camera, or it may be in use by another app.';
      } else if (lastError.name === 'NotReadableError') {
        reason = '⚙️ <strong>Camera is in use by another application.</strong><br>Close any other apps using the camera, then click Retry.';
      } else if (lastError.name === 'SecurityError') {
        reason = '🔐 <strong>Security restriction.</strong><br>Camera access requires HTTPS or localhost. Use the Upload Photo option instead.';
      } else {
        reason = `❌ ${lastError.name}: ${lastError.message}<br><br>Try the Upload Photo option instead.`;
      }
    }
    showCamError(captureBtn, errBox, status, reason || 'Camera unavailable. Use Upload Photo or Skip & Analyse.');
    return;
  }

  video.srcObject = mediaStream;
  video.onloadedmetadata = () => {
    status.textContent = '✓ Camera ready — align your face within the guide';
    captureBtn.disabled = false;
  };
}

function showCamError(captureBtn, errBox, status, html) {
  errBox.innerHTML = html;
  errBox.style.display = 'block';
  status.textContent = 'Camera unavailable';
  captureBtn.disabled = false;
  captureBtn.textContent = '⚡ Skip & Analyse Instead';
  // Remove existing listeners by replacing the button with a clone, then re-attach one handler
  const newBtn = captureBtn.cloneNode(true);
  captureBtn.parentNode.replaceChild(newBtn, captureBtn);
  newBtn.addEventListener('click', () => runAnalysis());
}

function stopCamera() {
  if (mediaStream) { mediaStream.getTracks().forEach(t=>t.stop()); mediaStream=null; }
}

function runAnalysis() {
  const preview = document.getElementById('camera-preview');
