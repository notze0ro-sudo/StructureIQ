  div.innerHTML = `<div class="avatar avatar-ai">◈</div><div class="bubble bubble-ai"><div class="typing"><span></span><span></span><span></span></div></div>`;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}
function removeTyping() {
  const el = document.getElementById('typing-indicator');
  if (el) el.remove();
}

async function sendMessage(text, imageDataUrl=null) {
  if (!state.apiKey || !state.model) { openSettings(); showToast('Please configure your AI model first'); return; }
  if (state.isTyping) return;
  state.isTyping = true;

  // Build user message content
  const userContent = [];
  if (imageDataUrl) {
    userContent.push({ type:'image_url', image_url:{ url: imageDataUrl }});
  }
  state.attachments.forEach(att => {
    if (att.type === 'image') userContent.push({ type:'image_url', image_url:{ url:att.data }});
  });
  if (text) userContent.push({ type:'text', text });

  const userMsg = userContent.length === 1 && userContent[0].type === 'text' ? text : userContent;

  // Render user message
  const displayText = text || (state.attachments.length ? '[Image / File attached]' : '');
  let userHtml = `<p>${escapeHtml(displayText)}</p>`;
  state.attachments.filter(a=>a.type==='image').forEach(a=>{
    userHtml += `<img src="${a.data}" alt="attachment" style="margin-top:6px;max-height:200px;object-fit:cover;">`;
  });
  state.attachments.filter(a=>a.type==='file').forEach(a=>{
    userHtml += `<div style="display:inline-flex;align-items:center;gap:6px;margin-top:6px;background:var(--surface2);padding:4px 10px;border-radius:8px;font-size:0.8rem;">📎 ${escapeHtml(a.name)}</div>`;
  });
  addMessage('user', userHtml, true);

  // Add to history
  state.chatHistory.push({ role:'user', content: userMsg });
  clearAttachments();

  // Memory context
  const memCtx = state.memory.length ? `\n\n[Memory from past sessions]:\n${state.memory.slice(-5).join('\n')}` : '';

  // Show typing
  showTyping();
  document.getElementById('send-btn').disabled = true;

  try {
    const messages = [
      { role:'system', content: SYSTEM_PROMPT + memCtx },
      ...state.chatHistory.slice(-20)
    ];

    const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
      method:'POST',
      headers:{
        'Authorization': `Bearer ${state.apiKey}`,
        'Content-Type': 'application/json',
        'HTTP-Referer': window.location.href,
        'X-Title': 'StructureIQ'
      },
      body: JSON.stringify({ model: state.model, messages, stream: true, max_tokens: 2048 })
    });

    if (!res.ok) {
      const err = await res.json().catch(()=>({}));
      throw new Error(err.error?.message || `HTTP ${res.status}`);
    }

    removeTyping();
    const msgDiv = addMessage('assistant', '');
    const bubble = msgDiv.querySelector('.bubble');
    let fullText = '';

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    while(true) {
      const { done, value } = await reader.read();
      if (done) break;
      const chunk = decoder.decode(value);
      const lines = chunk.split('\n').filter(l=>l.startsWith('data:'));
      for (const line of lines) {
        const data = line.replace('data:','').trim();
        if (data === '[DONE]') break;
        try {
          const j = JSON.parse(data);
          const delta = j.choices?.[0]?.delta?.content;
          if (delta) { fullText += delta; bubble.innerHTML = marked.parse(fullText); }
        } catch{}
      }
    }

    // Save to history
    state.chatHistory.push({ role:'assistant', content: fullText });
    localStorage.setItem('siq_history', JSON.stringify(state.chatHistory.slice(-40)));

    // Extract & save memory tidbits
    extractMemory(text, fullText);
    document.getElementById('messages-container').scrollTop = 999999;

  } catch(e) {
    removeTyping();
    addMessage('assistant', `⚠️ **Error:** ${e.message}\n\nPlease check your API key and model name in Settings.`);
  } finally {
    state.isTyping = false;
    document.getElementById('send-btn').disabled = false;
  }
}

function extractMemory(userMsg, aiReply) {
  // Simple keyword extraction for memory
  const keywords = ['my goal', 'i am', 'i have', 'my age', 'my name', 'i want', 'my jaw', 'my face', 'started mewing', 'i started'];
  const lower = (userMsg||'').toLowerCase();
  if (keywords.some(k => lower.includes(k))) {
    const snippet = `User said: "${(userMsg||'').slice(0,200)}"`;
    if (!state.memory.includes(snippet)) {
      state.memory.push(snippet);
      if (state.memory.length > 20) state.memory.shift();
      localStorage.setItem('siq_memory', JSON.stringify(state.memory));
    }
  }
}

function renderHistory() {
  if (!state.chatHistory.length) return;
  const container = document.getElementById('messages-container');
  const welcome = document.getElementById('welcome-state');
  if (welcome) welcome.remove();
  state.chatHistory.forEach(m => {
    const html = m.role==='assistant' ? marked.parse(typeof m.content==='string'?m.content:'…') : `<p>${typeof m.content==='string'?escapeHtml(m.content):'[Image message]'}</p>`;
    addMessage(m.role, html, true);
  });
}

